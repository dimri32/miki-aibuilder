# ── Stage 1: build ────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY nextjs/package*.json ./
RUN npm ci

# Copy source but explicitly exclude local dev env file
COPY nextjs/ ./
RUN rm -f .env.local .env

RUN mkdir -p public
RUN npm run build

# ── Stage 2: runtime ───────────────────────────────────────────────────────────
FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production

COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# # BACKEND_URL, API_USERNAME, API_PASSWORD are injected at runtime
# # via TrueFoundry deployment env vars — no build-time args needed
# CMD ["node", "server.js"]
